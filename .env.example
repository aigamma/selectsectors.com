# Supabase project URL for the existing aigamma.com Supabase
# (project ref tbxhvpoyyyhbvoyefggu). selectsectors.com reads the
# daily EOD universe from that project's daily_eod,
# daily_volatility_stats, and spx_intraday_bars tables read-only;
# the aigamma.com EOD pipeline is the upstream that writes those
# tables every weekday at 21:30 UTC.
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://tbxhvpoyyyhbvoyefggu.supabase.co

# Anonymous (publishable) key for the aigamma.com Supabase project.
# Read-only; RLS gates write paths so the anon key cannot mutate
# any table. Project Settings -> API -> anon public.
SUPABASE_ANON_KEY=

# Anthropic API key for the /api/chat function (SelectBot). Eric's
# personal key from console.anthropic.com works; set in Netlify
# project env vars (not committed). Without this set, the chat
# endpoint returns 503 and the chat panel hides itself.
ANTHROPIC_API_KEY=

# Auto-set by Netlify; do not configure manually outside of local
# dev. Documented here so the full set of env vars the functions
# read is visible in one place.
#
# URL: the deployed site URL (e.g., https://selectsectors.com). The
#   backtest + compare + scan dispatchers use this to construct the
#   fire-and-forget POST to the corresponding background function.
# DEPLOY_URL: the per-deploy URL (e.g.,
#   https://deploy-preview-12--selectsectors.netlify.app). Used as a
#   fallback by the dispatchers when URL is unset (preview deploys).
# COMMIT_REF: the git commit SHA of the current deploy. Surfaced
#   through /api/health's `commit` field for the operational catalog.
# DEPLOY_ID: the Netlify deploy ID. Surfaced through /api/health's
#   `deployId` field. Useful for correlating function logs with a
#   specific deploy in the Netlify dashboard.
URL=
DEPLOY_URL=
COMMIT_REF=
DEPLOY_ID=
