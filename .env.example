# Massive Market Data API key. Used by netlify/functions/refresh-data-background.mts
# to pull daily grouped-bars payloads for the 23-symbol universe.
# Same key shape as the aigamma.com production deployment; can be a
# Massive Stocks Starter + Indices Starter combination (no Options tier
# required for this site since chain-level data is out of scope).
MASSIVE_API_KEY=

# Supabase project URL for the dedicated selectsectors.com project.
# Separate from the aigamma.com project so the public-site read
# traffic does not interact with the dashboard's intraday write
# traffic. Format: https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase service-role key for the same project. Bypasses RLS and is
# required by the background function for upserts into daily_bars.
# Treat as a secret. Project Settings -> API -> service_role.
SUPABASE_SERVICE_KEY=

# Anonymous (publishable) key for the same Supabase project. Used by
# read-only function paths that benefit from RLS-scoped queries.
SUPABASE_ANON_KEY=

# Auto-set by Netlify to the deployed site URL (e.g.,
# https://selectsectors.com). Read by the refresh-tick scheduled
# function to build the URL for the background function dispatch.
# Do not set manually outside of local dev.
URL=
